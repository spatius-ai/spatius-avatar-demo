# Get Spatius App ID: https://app.spatius.ai/apps
# Get Spatius Avatar ID (more test avatars): https://app.spatius.ai/avatars/library
VITE_SPATIUS_APP_ID=your_spatius_app_id
VITE_SPATIUS_AVATAR_ID=aed008e4-8ddf-41aa-b5b2-5d7321dd4165

# This demo uses DrivingServiceMode.host (RTC transport), so no SPATIUS_SESSION_TOKEN
# is required. The LiveKit token is fetched at runtime from the token server in
# servers/python — see that directory's .env for LIVEKIT_URL / LIVEKIT_API_KEY / LIVEKIT_API_SECRET.
