# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Provider selection
# Supported values: openai, azure-openai, google, aws, ultravox, xai
E2E_PROVIDER=openai

# Optional shared instructions
AGENT_INSTRUCTIONS=You are a helpful voice assistant. Keep responses brief and natural.

# OpenAI Realtime
OPENAI_API_KEY=your_openai_api_key
E2E_OPENAI_MODEL=gpt-realtime
E2E_OPENAI_VOICE=alloy

# Azure OpenAI Realtime
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=wss://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
OPENAI_API_VERSION=2024-10-01-preview
E2E_AZURE_OPENAI_VOICE=alloy

# Google Gemini Live
GOOGLE_API_KEY=your_google_api_key
E2E_GOOGLE_MODEL=gemini-2.5-flash
E2E_GOOGLE_VOICE=Puck

# Amazon Nova Sonic
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
E2E_AWS_VOICE=tiffany
E2E_AWS_TURN_DETECTION=MEDIUM

# Ultravox Realtime
ULTRAVOX_API_KEY=your_ultravox_api_key
E2E_ULTRAVOX_VOICE=Mark

# xAI Grok Voice Agent API
XAI_API_KEY=your_xai_api_key
E2E_XAI_VOICE=ara

# Spatius Avatar
# Get your Spatius API credentials at: https://app.spatius.ai/
SPATIUS_API_KEY=your_key
SPATIUS_APP_ID=your_app_id
SPATIUS_AVATAR_ID=aed008e4-8ddf-41aa-b5b2-5d7321dd4165
