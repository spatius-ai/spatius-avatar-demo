# ── Server ────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8765
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001,http://127.0.0.1:3002,http://localhost:3002,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174,http://127.0.0.1:5175,http://localhost:5175,http://127.0.0.1:5178,http://localhost:5178

# ── Spatius ───────────────────────────────────────────────────
# Get credentials: https://app.spatius.ai/apps
# Get avatar IDs: https://app.spatius.ai/avatars/library
SPATIUS_APP_ID=your_spatius_app_id
SPATIUS_API_KEY=your_spatius_api_key
SPATIUS_AVATAR_ID=aed008e4-8ddf-41aa-b5b2-5d7321dd4165
SPATIUS_REGION=us-west

# Advanced override — only set if you are proxying or testing against a staging endpoint.
# Defaults are composed from SPATIUS_REGION.
# Region & endpoints: https://docs.spatius.ai/api-reference/regions
# SPATIUS_CONSOLE_ENDPOINT=https://console.us-west.spatius.ai/v1/console
# SPATIUS_INGRESS_ENDPOINT=wss://api.us-west.spatius.ai/v2/driveningress

AVATAR_OUTPUT_SAMPLE_RATE=16000
USER_INPUT_SAMPLE_RATE=16000

# ── ASR (Deepgram) ───────────────────────────────────────────────
# Get key: https://console.deepgram.com/
ASR_API_KEY=your_asr_api_key
ASR_MODEL=nova-3
ASR_LANGUAGE=en-US
ASR_BASE_URL=https://api.deepgram.com

# ── LLM (OpenAI-compatible) ──────────────────────────────────────
# Works with OpenAI, Doubao, or any OpenAI-compatible provider.
# OpenAI:  https://platform.openai.com/api-keys
# Doubao:  https://console.volcengine.com/ark
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_SYSTEM_PROMPT=You are a concise and friendly voice assistant.

# ── TTS (Cartesia) ───────────────────────────────────────────────
# Get key: https://play.cartesia.ai/
TTS_API_KEY=your_tts_api_key
TTS_MODEL=sonic-2
TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
TTS_BASE_URL=https://api.cartesia.ai
