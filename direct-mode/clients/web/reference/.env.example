# Get Spatius App ID:
# https://app.spatius.ai/apps
# Get Spatius Avatar ID (test avatars):
# https://app.spatius.ai/avatars/library
VITE_SPATIUS_APP_ID=your_spatius_app_id
VITE_SPATIUS_AVATAR_ID=aed008e4-8ddf-41aa-b5b2-5d7321dd4165

# OpenAI (direct browser calls, demo only)
VITE_OPENAI_API_KEY=sk-your_openai_api_key
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_STT_MODEL=gpt-4o-mini-transcribe
VITE_OPENAI_STT_LANGUAGE=en
VITE_OPENAI_TTS_MODEL=gpt-4o-mini-tts
VITE_OPENAI_TTS_VOICE=alloy

# Cartesia (optional)
VITE_CARTESIA_API_KEY=
VITE_CARTESIA_MODEL=sonic-2
VITE_CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02

# Local VAD parameters (tune by noise level)
VITE_VAD_START_THRESHOLD=0.02
VITE_VAD_STOP_THRESHOLD=0.014
VITE_VAD_SILENCE_MS=700
VITE_VAD_MIN_SPEECH_MS=280
