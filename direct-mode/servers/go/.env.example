# Get Spatius App ID / API Key:
# https://app.spatius.ai/apps
# Get Spatius Avatar ID (test avatars):
# https://app.spatius.ai/avatars/library
SPATIUS_API_KEY=your_spatius_api_key
SPATIUS_APP_ID=your_spatius_app_id
SPATIUS_REGION=us-west

# Advanced override — only set if you are proxying or testing against a staging endpoint.
# Defaults are composed from SPATIUS_REGION.
# Region & endpoints: https://docs.spatius.ai/api-reference/regions
# SPATIUS_CONSOLE_ENDPOINT=https://console.us-west.spatius.ai/v1/console
SESSION_TOKEN_TTL_MINUTES=55
TOKEN_SERVER_PORT=8090
TOKEN_MOCK_MODE=false
